GUM_LOG=0
HOME=/home/ubuntu
GIT_ROOT_DIR=$HOME/_git
GIT_STG_DIR=$GIT_ROOT_DIR/_stg
GIT_PRD_DIR=$GIT_ROOT_DIR/_prd
STG_DIR=$HOME/_stg
PRD_DIR=$HOME/_prd
PATH=$PATH:$GIT_ROOT_DIR/bash-tools
PATH=$PATH:$GIT_ROOT_DIR/oci-tools
PATH=$PATH:/usr/local/go/bin
PATH=$PATH:/snap/bin
PATH=$PATH:.
USER_ALIAS_FILE=$GIT_ROOT_DIR/oci-tools/bash/user-alias.yaml