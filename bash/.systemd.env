#!/bin/bash

#
# gum
#

export GUM_LOG=0

echo "HOME=${HOME}"
echo "PWD=$( cd ; echo ${PWD})"

#
# dir
#

export GIT_ROOT_DIR=/home/ubuntu/_git
export GIT_STG_DIR=${GIT_ROOT_DIR}/_stg
export GIT_PRD_DIR=${GIT_ROOT_DIR}/_prd
export STG_DIR=/home/ubuntu/_stg
export PRD_DIR=/home/ubuntu/_prd

#
# path
#

export PATH=${PATH}:${GIT_ROOT_DIR}/bash-tools
export PATH=${PATH}:${GIT_ROOT_DIR}/oci-tools
export PATH=${PATH}:.

print-info "PATH=${PATH}"

#
# alias
#

export USER_ALIAS_FILE=${GIT_ROOT_DIR}/oci-tools/bash/user-alias.yaml

print-info "USER_ALIAS_FILE=${USER_ALIAS_FILE}"