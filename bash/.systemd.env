#!/bin/bash

echo "${HOME}"

#
# dir
#

export GIT_ROOT_DIR=${HOME}/_git
export GIT_STG_DIR=${GIT_ROOT_DIR}/_stg
export GIT_PRD_DIR=${GIT_ROOT_DIR}/_prd
export STG_DIR=${HOME}/_stg
export PRD_DIR=${HOME}/_prd

#
# path
#

export PATH=${PATH}:${GIT_ROOT_DIR}/bash-tools
export PATH=${PATH}:${GIT_ROOT_DIR}/oci-tools
export PATH=${PATH}:.

print-info "PATH=${PATH}"

#
# helpers
#

func run-app {

    if [[ "${1}" == "amnezic" ]]; then
        BIN="amnezic-go/bin/amnezic-go"
    elif  [[ "${1}" == "amnezic" ]]; then
        BIN="games-go/bin/games-go"
    else
        print-error "unknown app! ( ${1} )"
        return
    fi
    shift

    if [[ "${1}" == "prd" ]]; then
        GIT_DIR=${GIT_PRD_DIR}
    elif  [[ "${1}" == "stg" ]]; then
        GIT_DIR=${GIT_STG_DIR}
    else
        print-error "unknown env! ( ${1} )"
        return
    fi

    print-cmd "go-run ${GIT_STG_DIR}/${BIN} $*"
    go-run ${GIT_STG_DIR}/${BIN} "$*"
}