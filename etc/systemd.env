#!/bin/bash

#
# gum
#

GUM_LOG=0

#
# home
#

HOME=/home/ubuntu

#
# dir
#

export GIT_ROOT_DIR=${HOME}/_git
export GIT_STG_DIR=${GIT_ROOT_DIR}/_stg
export GIT_PRD_DIR=${GIT_ROOT_DIR}/_prd
export STG_DIR=${HOME}/_stg
export PRD_DIR=${HOME}/_prd
export BASH_TOOLS_DIR=${GIT_ROOT_DIR}/bash-tools
export OCI_TOOLS_DIR=${GIT_ROOT_DIR}/oci-tools

#
# path
#

export PATH=${PATH}:${BASH_TOOLS_DIR}
export PATH=${PATH}:${OCI_TOOLS_DIR}
export PATH=${PATH}:/usr/local/go/bin
export PATH=${PATH}:/snap/bin
export PATH=${PATH}:.

#
# alias
#

export USER_ALIAS_FILE=${OCI_TOOLS_DIR}/etc/user-alias.yaml
