# http
server {
        server_name     media.grygry.ovh;
        listen          80;
        listen          [::]:80;

        access_log      /var/log/nginx/media.access.log;
        error_log       /var/log/nginx/media.error.log;

        root            /home/ubuntu/nginx/media;
        location / {
                try_files       $uri $uri/ =404;
                autoindex       on;
        }
}