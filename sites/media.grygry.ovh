#
# http
#

server {
        server_name             media.grygry.ovh;
        listen                  7002 default_server;
        listen                  [::]:7002 default_server;
    
        access_log              /var/nginx/log/media.log;
        error_log               /var/nginx/log/media.err;

        root                    /var/nginx/media;
        location / {
                try_files       $uri $uri/ $uri.html =404;
                # autoindex       on;
        }
}