# http > https
server {
    server_name             stg.games.grygry.ovh;
    listen                  80 default_server;
    
    return                  301 https://$server_name$request_uri;
}

# https
server {
    server_name             stg.games.grygry.ovh;
    listen                  443 default_server ssl;
    include                 /var/nginx/.conf/ssl.conf;

    location / {
        proxy_pass          http://localhost:7102;
    }
}