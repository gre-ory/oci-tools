#
# http
#

server {
        server_name             www.grygry.ovh;
        listen                  7000 default_server;
        listen                  [::]:7000 default_server;
    
        access_log              /var/nginx/log/www.log;
        error_log               /var/nginx/log/www.err;

        root                    /var/nginx/www;
        location / {
                try_files       $uri $uri/ =404;
                autoindex       on;
        }
}