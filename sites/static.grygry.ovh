# http
server {
        server_name     static.grygry.ovh;
        listen          80;
        listen          [::]:80;

        access_log      /var/log/nginx/static.access.log;
        error_log       /var/log/nginx/static.error.log;

        root            /home/ubuntu/nginx/static;
        location / {
                try_files       $uri $uri/ =404;
                autoindex       on;
        }
}