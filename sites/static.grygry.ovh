#
# http
#

server {
        server_name             static.grygry.ovh;
        listen                  7001 default_server;
        listen                  [::]:7001 default_server;
    
        access_log              /var/nginx/log/static.log;
        error_log               /var/nginx/log/static.err;

        root                    /var/nginx/static;
        location / {
                try_files       $uri $uri/ =404;
                autoindex       on;
        }
}