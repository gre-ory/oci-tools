# http > https
server {
        server_name             static.grygry.ovh;
        listen                  80 default_server;
    
        return                  301 https://$server_name$request_uri;
}

# https
server {
        server_name             static.grygry.ovh;
        listen                  443 default_server ssl;
        include                 /var/nginx/.conf/ssl.conf;

        access_log              /var/nginx/log/static.log;
        error_log               /var/nginx/log/static.log;

        root                    /var/nginx/static;
        location / {
                try_files       $uri $uri/ $uri.html =404;
                # autoindex       on;
        }
}