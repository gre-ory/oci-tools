#!/bin/bash

# global

CURRENT_DIR=$( dirname $0 )
SITES_DIR="${CURRENT_DIR}/sites"

# option

MODE="multi"
while [[ "${1}" =~ ^- ]]; do
    case "${1}" in
        -a|--all)       MODE="multi-all";;
        -m|--multi)     MODE="multi";;
        -o|--one)       MODE="one";;
        -s|--single)    MODE="one";;
        *)              print-error "unknown option ${1}"; exit 1;;
    esac
    shift
done

HOST="grygry.ovh"
if [[ "${1}" =~ ^www$ ]]; then
    PATTERN="www.${HOST}"
elif [[ "${1}" =~ ^media$ ]]; then
    PATTERN="media.${HOST}"
elif [[ "${1}" =~ ^amnezic$ ]]; then
    PATTERN="amnezic.${HOST}"
elif [[ "${1}" =~ ^api$ ]]; then
    PATTERN="api.amnezic.${HOST}"
elif [[ "${1}" =~ ^(game|games)$ ]]; then
    PATTERN="games.${HOST}"
else
    PATTERN="${1}"
fi

if [[ "${MODE}" == "multi-all" ]]; then
    ls ${SITES_DIR} | grep "${PATTERN}" | choose -a -h "Select sites"
elif [[ "${MODE}" == "multi" ]]; then
    ls ${SITES_DIR} | grep "${PATTERN}" | choose -m -h "Select sites"
else
    ls ${SITES_DIR} | grep "${PATTERN}" | choose -h "Select sites"
fi